# Preferred Gemini key for speech-to-text.
GEMINI_API_KEY=

# Optional Gemini model override.
GEMINI_MODEL=gemini-2.5-flash

# Optional advanced photo-analysis model overrides.
# Pass 1 (web-search research notes) falls back to GEMINI_RESEARCH_MODEL then GEMINI_MODEL.
GEMINI_PHOTO_RESEARCH_MODEL=
# Pass 2 (structured JSON photo summary) falls back to GEMINI_PHOTO_MODEL then GEMINI_MODEL.
GEMINI_PHOTO_STRUCTURED_MODEL=
# Shared override for photo analysis if you want one model for both photo passes.
GEMINI_PHOTO_MODEL=


# Enable transcription + analysis during memory creation.
TRANSCRIPTION_ENABLED=true

# Optional backend audio storage path.
AUDIO_STORAGE_DIR=/data/audio

# Keep false in normal use. Set true only for offline/demo mode.
ALLOW_PLACEHOLDER_TRANSCRIPT=false
